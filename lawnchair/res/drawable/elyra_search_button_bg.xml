<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright 2026, The Elyra Launcher Project. Licensed under the Apache License,
     Version 2.0. Rounded surface for the bottom-drawer color-search button so it
     reads as a deliberate companion to the search bar (same ?searchboxHighlight
     surface), instead of a bare floating icon. Ripple preserved for touch feedback.
     Original Elyra asset; no values copied from any source. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?android:colorControlHighlight">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
            <corners android:radius="1000dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?searchboxHighlight" />
            <corners android:radius="1000dp" />
        </shape>
    </item>
</ripple>
