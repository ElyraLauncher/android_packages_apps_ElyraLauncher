     Elyra design tokens (light / default). The drawer tokens provide one shared
     translucent surface and foreground family for the real All Apps components.
     The palette is an original Elyra identity (deep emerald base, mint / teal
     accent) and contains no values copied from any reference launcher.
     Dark-mode overrides live in values-night/elyra_tokens.xml. -->
<resources>
    <!-- Color tokens. The primary accent is the existing brand color
         @color/elyra_accent (defined in values/colors.xml); the tokens below
         extend that palette and must not redeclare it. -->
    <color name="elyra_accent_variant">#FF12806B</color>
    <color name="elyra_background">#FFF3FBF8</color>
    <color name="elyra_surface">#FFFFFFFF</color>
    <color name="elyra_surface_elevated">#FFEAF5F1</color>
    <color name="elyra_text_primary">#FF0C2E29</color>
    <color name="elyra_text_secondary">#FF3B5A53</color>

    <!-- Light drawer foregrounds. These are intentionally independent from the
         workspace/dynamic text attributes: the drawer owns a light tonal sheet,
         so its foreground must remain dark even over a bright wallpaper. -->
    <color name="elyra_drawer_text_primary">#FF142621</color>
    <color name="elyra_drawer_text_secondary">#C43F544E</color>
    <color name="elyra_drawer_app_label">#F20B211B</color>
    <color name="elyra_drawer_text_selected">#FF0B4B40</color>
    <color name="elyra_drawer_text_unselected">#E0142F28</color>
    <color name="elyra_drawer_search_hint">#B8465B55</color>
    <color name="elyra_drawer_search_cursor">#FF126B5B</color>
    <color name="elyra_drawer_icon_foreground">#E0142F28</color>

    <!-- Light drawer surface hierarchy. The root color is opaque because the
         verified sheet renderer applies its existing alpha during drawing. Child
         tokens carry their own translucency and are deliberately stronger than
         the root so cards and controls remain legible without becoming flat white. -->
    <color name="elyra_drawer_root_surface">#FFE3ECE8</color>
    <!-- Unified frosted component family. The root is drawn once with the user's
         drawer opacity. Level 1 is the shared in-sheet card/control layer; Level
         2 is the stronger selected/popup layer. Their translucent neutral-mint
         tones allow the wallpaper-aware root to influence every component
         without letting wallpaper detail overpower content. -->
    <color name="elyra_drawer_surface_level_1">#9EF3F8F5</color>
    <color name="elyra_drawer_surface_level_2">#BDF7FAF8</color>
    <color name="elyra_drawer_outline_level_1">#4736504A</color>
    <color name="elyra_drawer_outline_level_2">#5936504A</color>

    <!-- Component aliases keep ownership explicit while preventing independent
         per-view color and alpha choices. -->
    <color name="elyra_drawer_capsule_surface">@color/elyra_drawer_surface_level_1</color>
    <color name="elyra_drawer_elevated_card_surface">@color/elyra_drawer_surface_level_1</color>
    <color name="elyra_drawer_card_outline">@color/elyra_drawer_outline_level_1</color>
    <color name="elyra_drawer_suggestion_surface">@color/elyra_drawer_surface_level_1</color>
    <color name="elyra_drawer_card_surface">@color/elyra_drawer_surface_level_1</color>
    <color name="elyra_drawer_search_surface">@color/elyra_drawer_surface_level_1</color>
    <color name="elyra_drawer_button_surface">@color/elyra_drawer_surface_level_1</color>
    <color name="elyra_drawer_selected_pill_surface">@color/elyra_drawer_surface_level_2</color>
    <color name="elyra_drawer_popup_surface">@color/elyra_drawer_surface_level_2</color>
    <color name="elyra_drawer_index_popup_surface">@color/elyra_drawer_surface_level_2</color>
    <color name="elyra_drawer_surface_stroke">@color/elyra_drawer_outline_level_1</color>

    <!-- Compatibility alias retained for callers outside the refined drawer
         surfaces. New drawer controls use the component-specific tokens above. -->
    <color name="elyra_drawer_control_surface">@color/elyra_drawer_surface_level_1</color>

    <!-- Corner radius tokens -->
    <dimen name="elyra_radius_small">8dp</dimen>
    <dimen name="elyra_radius_medium">16dp</dimen>
    <dimen name="elyra_radius_large">24dp</dimen>
    <dimen name="elyra_radius_extra_large">32dp</dimen>

    <!-- Icon size tokens -->
    <dimen name="elyra_icon_size_small">40dp</dimen>
    <dimen name="elyra_icon_size_default">48dp</dimen>
    <dimen name="elyra_icon_size_large">56dp</dimen>

    <!-- Spacing tokens -->
    <dimen name="elyra_spacing_small">8dp</dimen>
    <dimen name="elyra_spacing_medium">16dp</dimen>
    <dimen name="elyra_spacing_large">24dp</dimen>

    <!-- Layout surface tokens -->
    <dimen name="elyra_search_bar_height">56dp</dimen>
    <dimen name="elyra_card_radius">20dp</dimen>
    <dimen name="elyra_folder_radius">28dp</dimen>
    <dimen name="elyra_dock_radius">28dp</dimen>

    <!-- Bottom drawer search row: a clean, symmetric side inset for the bottom
         search bar + color button, decoupled from the grid icon-alignment margin
         used by the top search bar, so the pill has a predictable width and its
         rounded ends stay fully visible and centered. -->
    <dimen name="elyra_bottom_search_side_padding">16dp</dimen>
    <dimen name="elyra_bottom_search_control_gap">12dp</dimen>
    <dimen name="elyra_bottom_search_bottom_spacing">10dp</dimen>
    <!-- Breathing space reserved in the app-content bottom padding ABOVE the
         bottom controls row, so the final app row and its labels always scroll
         clear of the controls. The container already sits at
         nav_inset + bottom_spacing + container_height; this is the additional
         clearance on top of that. Kept in the 12-16dp target range. -->
    <dimen name="elyra_bottom_search_content_spacing">16dp</dimen>
    <dimen name="elyra_drawer_header_height">46dp</dimen>
    <dimen name="elyra_drawer_segment_width">200dp</dimen>
    <dimen name="elyra_drawer_segment_height">44dp</dimen>
    <dimen name="elyra_drawer_segment_indicator_height">38dp</dimen>
    <dimen name="elyra_drawer_overflow_size">44dp</dimen>
    <dimen name="elyra_drawer_sheet_radius">32dp</dimen>
    <!-- Visual gap added once below the device's safe top inset (status bar /
         display cutout) so the rounded drawer-sheet top corners clear system UI.
         Device-adaptive: it is added on top of the real per-device top inset, not
         a fixed notch offset. -->
    <dimen name="elyra_drawer_safe_top_gap">10dp</dimen>
    <dimen name="elyra_fastscroll_popup_size">44dp</dimen>
    <dimen name="elyra_fastscroll_popup_text_size">20sp</dimen>
    <dimen name="elyra_fastscroll_rail_height">432dp</dimen>
    <dimen name="elyra_fastscroll_touch_width">32dp</dimen>
    <dimen name="elyra_fastscroll_index_text_size">9sp</dimen>
    <dimen name="elyra_fastscroll_end_margin">8dp</dimen>
    <dimen name="elyra_fastscroll_popup_margin">52dp</dimen>
    <dimen name="elyra_color_popup_padding">12dp</dimen>
    <dimen name="elyra_color_popup_anchor_gap">10dp</dimen>
    <dimen name="elyra_color_popup_elevation">10dp</dimen>

    <!-- Drawer color-filter panel tokens (Stage 6.7). A compact, evenly spaced
         row of color swatches with a clear highlight ring on the selected dot.
         Sizing lives here so the panel stays consistent and future-tunable. -->
    <dimen name="elyra_color_chip_cell_size">48dp</dimen>
    <dimen name="elyra_color_dot_size">30dp</dimen>
    <dimen name="elyra_color_dot_ring">2dp</dimen>
    <dimen name="elyra_color_dot_ring_gap">2dp</dimen>
    <dimen name="elyra_color_dot_hairline">1dp</dimen>

    <!-- Effective Level 0 floors are composed at render time without writing the
         user's opacity preference. System blur needs only a moderate tonal layer;
         the fallback is stronger so unsupported devices never show a nearly
         transparent, sharp wallpaper inside the drawer. Both remain translucent. -->
    <integer name="elyra_drawer_root_blur_alpha_floor">148</integer>
    <integer name="elyra_drawer_root_fallback_alpha_floor">198</integer>
    <integer name="elyra_drawer_sheet_alpha">206</integer>
</resources>
