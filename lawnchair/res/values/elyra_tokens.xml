<?xml version="1.0" encoding="utf-8"?>
<!-- Copyright 2026, The Elyra Launcher Project. Licensed under the Apache License, Version 2.0.

     Elyra design tokens (light / default). These are additive foundation tokens:
     no existing view references them yet, so they do not change current launcher
     behavior. The palette is an original Elyra identity (deep emerald base, mint /
     teal accent) and contains no values copied from any reference launcher.
     Dark-mode overrides live in values-night/elyra_tokens.xml. -->
<resources>
    <!-- Color tokens. The primary accent is the existing brand color
         @color/elyra_accent (defined in values/colors.xml); the tokens below
         extend that palette and must not redeclare it. -->
    <color name="elyra_accent_variant">#FF12806B</color>
    <color name="elyra_background">#FFF3FBF8</color>
    <color name="elyra_surface">#FFFFFFFF</color>
    <color name="elyra_surface_elevated">#FFEAF5F1</color>
    <color name="elyra_text_primary">#FF0C2E29</color>
    <color name="elyra_text_secondary">#FF3B5A53</color>
    <color name="elyra_drawer_surface_stroke">#240C2E29</color>
    <color name="elyra_drawer_control_surface">#C8FFFFFF</color>

    <!-- Corner radius tokens -->
    <dimen name="elyra_radius_small">8dp</dimen>
    <dimen name="elyra_radius_medium">16dp</dimen>
    <dimen name="elyra_radius_large">24dp</dimen>
    <dimen name="elyra_radius_extra_large">32dp</dimen>

    <!-- Icon size tokens -->
    <dimen name="elyra_icon_size_small">40dp</dimen>
    <dimen name="elyra_icon_size_default">48dp</dimen>
    <dimen name="elyra_icon_size_large">56dp</dimen>

    <!-- Spacing tokens -->
    <dimen name="elyra_spacing_small">8dp</dimen>
    <dimen name="elyra_spacing_medium">16dp</dimen>
    <dimen name="elyra_spacing_large">24dp</dimen>

    <!-- Layout surface tokens -->
    <dimen name="elyra_search_bar_height">56dp</dimen>
    <dimen name="elyra_card_radius">20dp</dimen>
    <dimen name="elyra_folder_radius">28dp</dimen>
    <dimen name="elyra_dock_radius">28dp</dimen>

    <!-- Bottom drawer search row: a clean, symmetric side inset for the bottom
         search bar + color button, decoupled from the grid icon-alignment margin
         used by the top search bar, so the pill has a predictable width and its
         rounded ends stay fully visible and centered. -->
    <dimen name="elyra_bottom_search_side_padding">16dp</dimen>
    <dimen name="elyra_bottom_search_control_gap">12dp</dimen>
    <dimen name="elyra_bottom_search_bottom_spacing">10dp</dimen>
    <!-- Breathing space reserved in the app-content bottom padding ABOVE the
         bottom controls row, so the final app row and its labels always scroll
         clear of the controls. The container already sits at
         nav_inset + bottom_spacing + container_height; this is the additional
         clearance on top of that. Kept in the 12-16dp target range. -->
    <dimen name="elyra_bottom_search_content_spacing">16dp</dimen>
    <dimen name="elyra_drawer_header_height">46dp</dimen>
    <dimen name="elyra_drawer_segment_width">200dp</dimen>
    <dimen name="elyra_drawer_segment_height">44dp</dimen>
    <dimen name="elyra_drawer_segment_indicator_height">38dp</dimen>
    <dimen name="elyra_drawer_overflow_size">44dp</dimen>
    <dimen name="elyra_drawer_sheet_radius">32dp</dimen>
    <dimen name="elyra_fastscroll_popup_size">44dp</dimen>
    <dimen name="elyra_fastscroll_popup_text_size">20sp</dimen>
    <dimen name="elyra_fastscroll_rail_height">432dp</dimen>
    <dimen name="elyra_fastscroll_touch_width">32dp</dimen>
    <dimen name="elyra_fastscroll_index_text_size">9sp</dimen>
    <dimen name="elyra_fastscroll_end_margin">8dp</dimen>
    <dimen name="elyra_fastscroll_popup_margin">52dp</dimen>
    <dimen name="elyra_color_popup_padding">12dp</dimen>
    <dimen name="elyra_color_popup_anchor_gap">10dp</dimen>
    <dimen name="elyra_color_popup_elevation">10dp</dimen>

    <!-- Drawer color-filter panel tokens (Stage 6.7). A compact, evenly spaced
         row of color swatches with a clear highlight ring on the selected dot.
         Sizing lives here so the panel stays consistent and future-tunable. -->
    <dimen name="elyra_color_chip_cell_size">48dp</dimen>
    <dimen name="elyra_color_dot_size">30dp</dimen>
    <dimen name="elyra_color_dot_ring">2dp</dimen>
    <dimen name="elyra_color_dot_ring_gap">2dp</dimen>
    <dimen name="elyra_color_dot_hairline">1dp</dimen>

    <!-- Coherent translucent surface alphas (0-255) for drawer chrome. Shared by
         the segmented capsule, category cards and the color panel so the drawer
         reads as one Elyra/Material surface language. Prepared for future
         user-facing surface customization; adopt incrementally. -->
    <integer name="elyra_surface_alpha_panel">214</integer>
    <integer name="elyra_surface_alpha_capsule">190</integer>
    <integer name="elyra_surface_alpha_card">196</integer>
    <integer name="elyra_surface_alpha_suggestion">200</integer>
    <integer name="elyra_surface_alpha_hairline">40</integer>
    <integer name="elyra_drawer_sheet_alpha">184</integer>
</resources>
