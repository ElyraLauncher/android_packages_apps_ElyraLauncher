    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep emerald field. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="42"
                android:centerY="38"
                android:gradientRadius="104"
                android:startColor="#FF1D5C4C"
                android:centerColor="#FF123E36"
                android:endColor="#FF08231F" />
        </aapt:attr>
    </path>

